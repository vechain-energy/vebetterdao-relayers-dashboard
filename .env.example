# Local VeChain mainnet RPC override used by Node-side report scripts.
MAINNET_NODE_URL=https://mainnet.vechain.org

# Optional browser-side overrides for the in-app `/run` flow.
# Set these when the relayer runner should use a custom public RPC endpoint.
# NEXT_PUBLIC_MAINNET_NODE_URL=https://mainnet.vechain.org
# NEXT_PUBLIC_TESTNET_NODE_URL=https://testnet.vechain.org

# Optional runtime report override for builds that should read report.json from
# a URL instead of the bundled /data/report.json asset.
# NEXT_PUBLIC_REPORT_URL=https://raw.githubusercontent.com/vechain-energy/vebetterdao-relayers-dashboard/main/public/data/report.json
